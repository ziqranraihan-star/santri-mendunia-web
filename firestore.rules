rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── Users Collection ─────────────────────────────────────────────
    // User bisa baca/update data diri sendiri. Admin bisa baca semua.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated();
    }

    // ─── Berita (News) ────────────────────────────────────────────────
    // Public bisa baca berita aktif. Hanya admin yang bisa write.
    match /santri_news/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Beasiswa (Scholarships) ──────────────────────────────────────
    match /scholarships/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Kursus (Courses) ─────────────────────────────────────────────
    match /courses/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Produk INKOPONTREN ───────────────────────────────────────────
    match /products/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Job & Magang ─────────────────────────────────────────────────
    match /jobs/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Donasi ───────────────────────────────────────────────────────
    match /donations/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Tour & Travel ────────────────────────────────────────────────
    match /trips/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Tes / Sertifikasi ────────────────────────────────────────────
    match /tests/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── E-Book / Ruang Kerja ─────────────────────────────────────────
    match /ebooks/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Mentor / Info Pesantren ──────────────────────────────────────
    match /mentors/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Banner ───────────────────────────────────────────────────────
    match /banners/{docId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Notifications ────────────────────────────────────────────────
    // User authenticated bisa baca notifikasi mereka. Admin bisa write.
    match /notifications/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Transactions / Orders ────────────────────────────────────────
    match /transactions/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ─── Categories ───────────────────────────────────────────────────
    match /categories/{docId} {
      allow read: if true;  // Public
      allow write: if isAdmin();
    }
  }
}
